{
  "broker": {
    "host": "mqtt-broker",
    "port": 1883,
    "clientId": "pdd_tb_gateway",
    "version": 5,
    "keepAlive": 60,
    "cleanSession": true,
    "cleanStart": true,
    "sessionExpiryInterval": 0,
    "security": {
      "type": "anonymous"
    }
  },
  "mapping": [
    {
      "topicFilter": "pallet_defect_detection",
      "subscriptionQos": 1,
      "converter": {
        "type": "custom",
        "extension": "PddCountsUplinkConverter",
        "cached": true,
        "extension-config": {
          "deviceName": "pallet-defect-detection-edge",
          "deviceType": "default",
          "logEveryN": 10,
          "logTracks": true,
          "persistTotals": true,
          "resetOnStart": true,
          "saveEveryN": 50,
          "totalsPath": "/var/lib/thingsboard_gateway/data/pdd_counts_totals.json",
          "countLine": { "x1": 0.45, "y1": 0.0, "x2": 0.45, "y2": 1.0 },
          "countDirection": "neg_to_pos",
          "iouThreshold": 0.25,
          "highConf": 0.6,
          "lowConf": 0.1,
          "maxLostFrames": 30,
          "defectIouThreshold": 0.1,
          "defectConfThreshold": 0.5
        }
      }
    }
  ],
  "requestsMapping": {}
}
