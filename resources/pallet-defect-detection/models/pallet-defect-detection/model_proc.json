{
    "json_schema_version": "2.2.0",
    "input_preproc": [
        {
            "params": {
                "resize": "aspect-ratio",
                "range": [
                    0.0,
                    1.0
                ]
            }
        }
    ],
    "output_postproc": [
        {
            "converter": "yolo_v8",
            "confidence_threshold": 0.5,
            "iou_threshold": 0.45,
            "labels": [
                "defect",
                "box"
            ]
        }
    ]
}